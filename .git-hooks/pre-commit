#!/bin/sh
#
# Pre-commit hook to lint Ruby and YAML files
# This hook runs RuboCop on .rb files and yamllint on .yml/.yaml files
#
# To install this hook, run:
#   cp .git-hooks/pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit

echo "Running pre-commit linters..."

# Get list of staged Ruby files
RUBY_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.rb$')

# Get list of staged YAML files
YAML_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(yml|yaml)$')

# Track if any linting failed
LINT_FAILED=0

# Run RuboCop on staged Ruby files
if [ -n "$RUBY_FILES" ]; then
  echo "Linting Ruby files with RuboCop..."
  bundle exec rubocop -a $RUBY_FILES
  RUBOCOP_EXIT=$?
  
  if [ $RUBOCOP_EXIT -ne 0 ]; then
    echo "❌ RuboCop found issues in Ruby files"
    LINT_FAILED=1
  else
    echo "✅ RuboCop passed"
  fi
  
  # Re-add files that were auto-corrected
  git add $RUBY_FILES
fi

# Run yamllint on staged YAML files
if [ -n "$YAML_FILES" ]; then
  echo "Linting YAML files with yamllint..."
  yamllint $YAML_FILES
  YAMLLINT_EXIT=$?
  
  if [ $YAMLLINT_EXIT -ne 0 ]; then
    echo "❌ yamllint found issues in YAML files"
    LINT_FAILED=1
  else
    echo "✅ yamllint passed"
  fi
fi

# Exit with error if any linter failed
if [ $LINT_FAILED -ne 0 ]; then
  echo ""
  echo "⚠️  Linting found issues. Please fix them before committing."
  echo "   RuboCop may have auto-corrected some issues - review and stage them."
  exit 1
fi

echo "✅ All linting checks passed!"
exit 0
