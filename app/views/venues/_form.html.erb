<%= form_with(model: venue, class: "space-y-6") do |form| %>
  <% if venue.errors.any? %>
    <div class="alert alert-error">
      <div>
        <h2 class="font-bold"><%= pluralize(venue.errors.count, "error") %> prohibited this venue from being saved:</h2>
        <ul class="list-disc list-inside mt-2">
          <% venue.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>

  <fieldset class="fieldset">
    <legend class="fieldset-legend">Venue Details</legend>

    <div class="form-control w-full">
      <%= form.label :name, class: "label" %>
      <%= form.text_field :name, class: "input input-bordered w-full", placeholder: "Enter venue name" %>
    </div>

    <div class="form-control w-full">
      <%= form.label :venue_type, "Type", class: "label" %>
      <%= form.select :venue_type,
          options_for_select([['Bar', 'bar'], ['Club', 'club'], ['Festival', 'festival'], ['Gallery', 'gallery']], venue.venue_type),
          { prompt: 'Select venue type' },
          class: "select select-bordered w-full" %>
    </div>
  </fieldset>

  <fieldset class="fieldset">
    <legend class="fieldset-legend">Location</legend>

    <div data-controller="map-picker"
         data-map-picker-api-key-value="<%= Settings.google_maps_api_key %>"
         data-map-picker-default-lat-value="<%= @default_location[:lat] %>"
         data-map-picker-default-lng-value="<%= @default_location[:lng] %>">

      <!-- Address Search -->
      <div class="form-control w-full mb-4">
        <%= form.label :address_search, "Search Address", class: "label" %>
        <input type="text"
               data-map-picker-target="search"
               class="input input-bordered w-full"
               placeholder="Search for an address..." />
        <label class="label">
          <span class="label-text-alt">Search for an address or click on the map to set coordinates</span>
        </label>
      </div>

      <!-- Map Container -->
      <div data-map-picker-target="map"
           class="w-full h-96 rounded-lg border border-base-300 mb-4">
      </div>
    </div>
  </fieldset>

  <fieldset class="fieldset">
    <legend class="fieldset-legend">Address</legend>

    <%# Build states-by-country data from Carmen for the Stimulus controller %>
    <% states_json = Carmen::Country.all.each_with_object({}) do |country, hash|
         subregions = country.subregions.map(&:name)
         hash[country.alpha_2_code] = subregions if subregions.any?
       end.to_json %>

    <div data-controller="address-form"
         data-address-form-states-value="<%= states_json %>">

      <div class="form-control w-full">
        <%= form.label :address_line1, "Address Line 1", class: "label" %>
        <%= form.text_field :address_line1,
            class: "input input-bordered w-full",
            placeholder: "Street address, PO box",
            data: { address_form_target: "line1" } %>
      </div>

      <div class="form-control w-full">
        <%= form.label :address_line2, "Address Line 2", class: "label" %>
        <%= form.text_field :address_line2,
            class: "input input-bordered w-full",
            placeholder: "Apartment, suite, unit, building (optional)",
            data: { address_form_target: "line2" } %>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="form-control w-full">
          <%= form.label :city, class: "label" %>
          <%= form.text_field :city,
              class: "input input-bordered w-full",
              placeholder: "City / suburb",
              data: { address_form_target: "city" } %>
        </div>

        <div class="form-control w-full">
          <%= form.label :postcode, "Postcode / ZIP", class: "label" %>
          <%= form.text_field :postcode,
              class: "input input-bordered w-full",
              placeholder: "Postcode",
              data: { address_form_target: "postcode" } %>
        </div>
      </div>

      <div class="form-control w-full">
        <%= form.label :country, class: "label" %>
        <%= form.select :country,
            options_for_select(Carmen::Country.all.map { |c| [c.name, c.alpha_2_code] }, venue.country),
            { prompt: 'Select country' },
            class: "select select-bordered w-full",
            data: {
              address_form_target: "country",
              action: "address-form#countryChanged"
            } %>
      </div>

      <div class="form-control w-full">
        <%= form.label :state, "State / Province", class: "label" %>
        <%= form.select :state,
            options_for_select([]),
            { prompt: 'Select state / province' },
            class: "select select-bordered w-full",
            data: { address_form_target: "state" } %>
      </div>
    </div>
  </fieldset>

  <div class="flex gap-2">
    <%= form.submit class: "btn btn-primary" %>
    <%= link_to "Cancel", venue.persisted? ? venue : venues_path, class: "btn btn-ghost" %>
  </div>
<% end %>
