<div class="container mx-auto px-4 py-8">
  <div class="card bg-base-100 shadow-xl">
    <div class="card-body">
      <div class="flex justify-between items-start mb-6">
        <div>
          <h1 class="text-3xl font-bold mb-2">Performance Details</h1>
          <div class="badge badge-primary badge-lg"><%= @performance.time.strftime("%B %d, %Y at %I:%M %p") if @performance.time %></div>
        </div>
        <div class="flex gap-2">
          <%= link_to "Edit", edit_performance_path(@performance), class: "btn btn-primary" %>
          <%= button_to "Delete", @performance, method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "btn btn-error" %>
        </div>
      </div>

      <div class="divider"></div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <p class="text-sm text-base-content/70 mb-1">Time</p>
          <p class="text-lg font-medium">
            <%= @performance.time.strftime("%B %d, %Y") if @performance.time %>
            <br>
            <span class="text-base"><%= @performance.time.strftime("%I:%M %p") if @performance.time %></span>
          </p>
        </div>

        <div>
          <p class="text-sm text-base-content/70 mb-1">Performer</p>
          <% if @performance.performer %>
            <div class="flex items-center gap-3">
              <div class="avatar placeholder">
                <div class="bg-primary text-primary-content rounded-full w-12">
                  <span><%= @performance.performer.name.first.upcase %></span>
                </div>
              </div>
              <div>
                <p class="text-lg font-medium"><%= @performance.performer.name %></p>
                <%= link_to "View Performer", @performance.performer, class: "link link-primary text-sm" %>
              </div>
            </div>
          <% end %>
        </div>

        <div>
          <p class="text-sm text-base-content/70 mb-1">Event</p>
          <% if @performance.event %>
            <p class="text-lg font-medium"><%= @performance.event.title %></p>
            <%= link_to "View Event", @performance.event, class: "link link-primary text-sm" %>
          <% end %>
        </div>

        <div>
          <p class="text-sm text-base-content/70 mb-1">Venue</p>
          <% if @performance.event&.venue %>
            <p class="text-lg font-medium"><%= @performance.event.venue.name %></p>
            <%= link_to "View Venue", @performance.event.venue, class: "link link-primary text-sm" %>
          <% else %>
            <p class="text-base-content/50">No venue assigned</p>
          <% end %>
        </div>
      </div>

      <% if @performance.event&.venue&.location.present? %>
        <div class="divider"></div>
        <% venue = @performance.event.venue %>
        <div>
          <p class="text-sm text-base-content/70 mb-1">Location — <%= venue.name %></p>
          <div class="space-y-2 mt-2">
            <p class="text-sm">
              <span class="text-base-content/70">Lat:</span> <%= venue.latitude %> |
              <span class="text-base-content/70">Lng:</span> <%= venue.longitude %>
            </p>
            <div class="w-full rounded-lg border border-base-300 overflow-hidden bg-base-200"
                 style="height: 576px"
                 data-controller="map-display"
                 data-map-display-latitude-value="<%= venue.latitude %>"
                 data-map-display-longitude-value="<%= venue.longitude %>">
            </div>
            <a href="https://www.google.com/maps?q=<%= venue.latitude %>,<%= venue.longitude %>"
               target="_blank"
               class="link link-primary text-sm">
              Open in Google Maps &rarr;
            </a>
          </div>
        </div>
      <% end %>

      <div class="card-actions justify-start mt-6">
        <%= link_to "Back to Performances", performances_path, class: "btn btn-ghost" %>
      </div>
    </div>
  </div>
</div>
