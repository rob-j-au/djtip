<%= form_with(model: performance, class: "space-y-6") do |form| %>
  <% if performance.errors.any? %>
    <div class="alert alert-error">
      <div>
        <h2 class="font-bold"><%= pluralize(performance.errors.count, "error") %> prohibited this performance from being saved:</h2>
        <ul class="list-disc list-inside mt-2">
          <% performance.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>

  <fieldset class="fieldset">
    <legend class="fieldset-legend">Performance Details</legend>
    
    <div class="form-control w-full">
      <%= form.label :time, class: "label" %>
      <%= form.datetime_field :time, class: "input input-bordered w-full" %>
    </div>

    <div class="form-control w-full">
      <%= form.label :performer_id, "Performer", class: "label" %>
      <%= form.collection_select :performer_id, @performers, :id, :name, 
          { prompt: 'Select a performer' },
          class: "select select-bordered w-full" %>
    </div>

    <div class="form-control w-full">
      <%= form.label :event_id, "Event", class: "label" %>
      <%= form.collection_select :event_id, @events, :id, :title, 
          { prompt: 'Select an event' },
          class: "select select-bordered w-full" %>
    </div>
  </fieldset>

  <fieldset class="fieldset">
    <legend class="fieldset-legend">Location (Optional)</legend>
    
    <div data-controller="map-picker"
         data-map-picker-api-key-value="<%= ENV['GOOGLE_MAPS_API_KEY'] || 'YOUR_API_KEY_HERE' %>"
         data-map-picker-default-lat-value="<%= @default_location[:lat] %>"
         data-map-picker-default-lng-value="<%= @default_location[:lng] %>">
      
      <!-- Address Search -->
      <div class="form-control w-full mb-4">
        <%= form.label :address_search, "Search Address", class: "label" %>
        <input type="text" 
               data-map-picker-target="search"
               class="input input-bordered w-full" 
               placeholder="Search for an address..." />
        <label class="label">
          <span class="label-text-alt">Search and click on the map to set location</span>
        </label>
      </div>

      <!-- Map Container -->
      <div data-map-picker-target="map" 
           class="w-full h-96 rounded-lg border border-base-300 mb-4">
      </div>

      <!-- Coordinate Inputs -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="form-control w-full">
          <%= form.label :latitude, class: "label" %>
          <%= form.number_field :latitude, 
              step: :any, 
              class: "input input-bordered w-full", 
              placeholder: "e.g., -33.8688",
              data: { 
                map_picker_target: "latitude",
                action: "change->map-picker#latitudeChanged"
              } %>
          <label class="label">
            <span class="label-text-alt">Range: -90 to 90</span>
          </label>
        </div>

        <div class="form-control w-full">
          <%= form.label :longitude, class: "label" %>
          <%= form.number_field :longitude, 
              step: :any, 
              class: "input input-bordered w-full", 
              placeholder: "e.g., 151.2093",
              data: { 
                map_picker_target: "longitude",
                action: "change->map-picker#longitudeChanged"
              } %>
          <label class="label">
            <span class="label-text-alt">Range: -180 to 180</span>
          </label>
        </div>
      </div>
    </div>
  </fieldset>

  <div class="flex gap-2">
    <%= form.submit class: "btn btn-primary" %>
    <%= link_to "Cancel", performance.persisted? ? performance : performances_path, class: "btn btn-ghost" %>
  </div>
<% end %>
