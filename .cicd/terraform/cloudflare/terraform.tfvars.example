# Cloudflare API Token
# Get from: https://dash.cloudflare.com/profile/api-tokens
# Permissions: Zone → DNS → Edit
# Zone: djtip.jennings.au
cloudflare_api_token = "your-cloudflare-api-token-here"

# Domain (usually don't need to change)
domain = "djtip.jennings.au"

# Development IP (Minikube)
# Get with: minikube ip
dev_ip = "192.168.49.2"

# Note: staging_ip and prod_ip are automatically fetched from pi.jennings.au
# Your Cloudflare DDNS keeps pi.jennings.au updated, and Terraform uses that IP
# for the *.staging.djtip.jennings.au and *.djtip.jennings.au wildcards
