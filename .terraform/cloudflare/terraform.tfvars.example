# Cloudflare API Token
# Get from: https://dash.cloudflare.com/profile/api-tokens
# Permissions: Zone → DNS → Edit
# Zone: base-domain.org
cloudflare_api_token = "your-cloudflare-api-token-here"

# Domain (usually don't need to change)
domain = "base-domain.org"

# Development IP (Minikube)
# Get with: minikube ip
dev_ip = "192.168.49.2"

# Note: staging_ip and prod_ip are automatically fetched from the base domain
# Terraform reads the IP from the domain's DNS record and uses it for wildcards
# This allows automatic sync when your DDNS updates the base domain
